-- OFFER CARD BUILDER
--------------------------------------------------------------------------------
local function CreateOfferCard(parent, offer, isHostOffer)
    if not parent or not parent.Parent then return nil end
    if not offer then return nil end
    
    local rid = tostring(offer.roomId or offer.offerId or offer.from or HttpService:GenerateGUID(false))
    local playerName = isHostOffer and (offer.from or offer.username or "Unknown") or (offer.host or offer.username or "Unknown")
    local itemName = isHostOffer and (offer.name or offer.item or "Item") or (offer.item or "Item")
    local valueText = isHostOffer and (offer.generationText or offer.valueText or "") or (offer.valueText or "")
    local valueNum = tonumber(isHostOffer and (offer.generation or offer.valueNumber or 0) or (offer.valueNumber or 0)) or 0

    if playerName == "Unknown" or playerName == "" then
        return nil
    end

    local displayValue = valueText
    if displayValue == "" or displayValue == "$0" then
        displayValue = FormatNumber(valueNum) .. "/s"
    end

    local isMine = IsMyOffer(offer)
    local cardHeight = isHostOffer and 64 or 56

    local frame = Instance.new("Frame")
    frame.Name = (isHostOffer and "HostOffer_" or "Offer_") .. rid
    frame.Size = UDim2.new(1, 0, 0, cardHeight)
    frame.BackgroundColor3 = isMine and Color3.fromRGB(20, 18, 10) or Colors.Card
    frame.BorderSizePixel = 0
    frame.ClipsDescendants = true
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)

    local frameStroke = Instance.new("UIStroke", frame)
    frameStroke.Color = isMine and Color3.fromRGB(80, 70, 30) or Colors.Border
    frameStroke.Thickness = 1

    local accent = Instance.new("Frame", frame)
    accent.Size = UDim2.new(0, 3, 0, 24)
    accent.Position = UDim2.new(0, 0, 0.5, -12)
    accent.BackgroundColor3 = isMine and Colors.Success or Colors.Accent
    accent.BorderSizePixel = 0
    Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 2)

    local nameLbl = Instance.new("TextLabel", frame)
    nameLbl.Text = playerName
    nameLbl.TextColor3 = Colors.TextPrimary
    nameLbl.Font = Enum.Font.GothamBold
    nameLbl.TextSize = 12
    nameLbl.Position = UDim2.new(0, 14, 0, 8)
    nameLbl.Size = UDim2.new(0, 200, 0, 18)
    nameLbl.BackgroundTransparency = 1
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local copyBtn = Instance.new("TextButton", frame)
    copyBtn.Text = "📋"
    copyBtn.Size = UDim2.new(0, 24, 0, 18)
    copyBtn.BackgroundTransparency = 1
    copyBtn.TextColor3 = Colors.TextMuted
    copyBtn.Font = Enum.Font.Gotham
    copyBtn.TextSize = 11
    copyBtn.Position = UDim2.new(0, 220, 0, 8)

    copyBtn.MouseEnter:Connect(function() Tween(copyBtn, {TextColor3 = Colors.Accent}, 0.15) end)
    copyBtn.MouseLeave:Connect(function() Tween(copyBtn, {TextColor3 = Colors.TextMuted}, 0.15) end)
    copyBtn.MouseButton1Click:Connect(function()
        CopyToClipboard(playerName)
        copyBtn.Text = "✓"
        Tween(copyBtn, {TextColor3 = Colors.Success}, 0.15)
        task.delay(1.2, function()
            if copyBtn and copyBtn.Parent then
                copyBtn.Text = "📋"
                Tween(copyBtn, {TextColor3 = Colors.TextMuted}, 0.3)
            end
        end)
    end)

    local infoLbl = Instance.new("TextLabel", frame)
    infoLbl.Name = "ItemInfo"
    infoLbl.Text = itemName .. "  ·  " .. displayValue
    infoLbl.TextColor3 = Colors.Accent
    infoLbl.Font = Enum.Font.Gotham
    infoLbl.TextSize = 11
    infoLbl.Position = UDim2.new(0, 14, 0, 28)
    infoLbl.Size = UDim2.new(0, 350, 0, 16)
    infoLbl.BackgroundTransparency = 1
    infoLbl.TextXAlignment = Enum.TextXAlignment.Left

    if isMine and not isHostOffer then
        local tag = Instance.new("Frame", frame)
        tag.Size = UDim2.new(0, 70, 0, 20)
        tag.Position = UDim2.new(1, -160, 0.5, -10)
        tag.BackgroundColor3 = Color3.fromRGB(50, 45, 20)
        tag.BorderSizePixel = 0
        Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 6)

        local tagLbl = Instance.new("TextLabel", tag)
        tagLbl.Text = "YOURS"
        tagLbl.TextColor3 = Colors.Accent
        tagLbl.Font = Enum.Font.GothamBold
        tagLbl.TextSize = 9
        tagLbl.Size = UDim2.new(1, 0, 1, 0)
        tagLbl.BackgroundTransparency = 1
    end

    if isHostOffer then
        local btnAccept = Instance.new("TextButton", frame)
        btnAccept.Text = "✓ ACCEPT"
        btnAccept.Size = UDim2.new(0, 80, 0, 28)
        btnAccept.Position = UDim2.new(1, -172, 0.5, -14)
        btnAccept.BackgroundColor3 = Colors.Success
        btnAccept.TextColor3 = Color3.fromRGB(10, 10, 10)
        btnAccept.Font = Enum.Font.GothamBold
        btnAccept.TextSize = 10
        btnAccept.AutoButtonColor = false
        Instance.new("UICorner", btnAccept).CornerRadius = UDim.new(0, 7)
        HoverBind(btnAccept, Colors.Success, Color3.fromRGB(140, 220, 100), Color3.fromRGB(100, 180, 60))
        btnAccept.MouseButton1Click:Connect(function() RippleEffect(btnAccept) end)

        local btnReject = Instance.new("TextButton", frame)
        btnReject.Text = "✕ REJECT"
        btnReject.Size = UDim2.new(0, 80, 0, 28)
        btnReject.Position = UDim2.new(1, -84, 0.5, -14)
        btnReject.BackgroundColor3 = Colors.Danger
        btnReject.TextColor3 = Color3.fromRGB(255, 255, 255)
        btnReject.Font = Enum.Font.GothamBold
        btnReject.TextSize = 10
        btnReject.AutoButtonColor = false
        Instance.new("UICorner", btnReject).CornerRadius = UDim.new(0, 7)
        HoverBind(btnReject, Colors.Danger, Color3.fromRGB(220, 80, 80), Color3.fromRGB(160, 40, 40))
        btnReject.MouseButton1Click:Connect(function() RippleEffect(btnReject) end)

        spawn(function()
            accent.BackgroundColor3 = Colors.Accent
            for i = 1, 3 do
                Tween(frameStroke, {Color = Colors.AccentDark}, 0.15)
                task.wait(0.2)
                Tween(frameStroke, {Color = Colors.Border}, 0.15)
                task.wait(0.2)
            end
        end)
    else
        if not isMine then
            local offerBtn = Instance.new("TextButton", frame)
            offerBtn.Text = "OFFER ▶"
            offerBtn.Size = UDim2.new(0, 76, 0, 28)
            offerBtn.Position = UDim2.new(1, -84, 0.5, -14)
            offerBtn.BackgroundColor3 = Colors.Accent
            offerBtn.TextColor3 = Color3.fromRGB(10, 10, 10)
            offerBtn.Font = Enum.Font.GothamBold
            offerBtn.TextSize = 10
            offerBtn.AutoButtonColor = false
            Instance.new("UICorner", offerBtn).CornerRadius = UDim.new(0, 7)
            HoverBind(offerBtn, Colors.Accent, Colors.AccentBright, Colors.AccentDark)
            offerBtn.MouseButton1Click:Connect(function() RippleEffect(offerBtn) end)
        end
    end

    frame.BackgroundTransparency = 0.6
    frame.Parent = parent
    Tween(frame, {BackgroundTransparency = 0}, 0.35, Enum.EasingStyle.Quart)

    return frame
end

--------------------------------------------------------------------------------
-- SEARCH FILTERING
--------------------------------------------------------------------------------
local function FilterOffers(query)
    if not PageOffers or not PageOffers.Parent then return end
    query = string.lower(query or "")
    
    local hasVisible = false
    for _, child in pairs(PageOffers:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("^Offer_") then
            local itemLabel = child:FindFirstChild("ItemInfo")
            if itemLabel then
                local itemText = string.lower(itemLabel.Text)
                local shouldShow = (query == "" or string.find(itemText, query, 1, true))
                
                child.Visible = shouldShow
                if shouldShow then hasVisible = true end
            end
        end
    end
    
    local empty = PageOffers:FindFirstChild("EmptyState")
    if empty then
        if query ~= "" and not hasVisible then
            empty.Text = "🔍  No results for \"" .. query .. "\""
            empty.Visible = true
        elseif #allOffers == 0 then
            empty.Text = "⏳  Waiting for offers..."
            empty.Visible = true
        else
            empty.Visible = not hasVisible
        end
    end
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    currentSearchQuery = SearchBox.Text
    FilterOffers(currentSearchQuery)
end)

--------------------------------------------------------------------------------
-- UPDATE OFFERS LIST
--------------------------------------------------------------------------------
local function UpdateOffersList(data)
    if not data then return end
    allOffers = data
    
    if not PageOffers or not PageOffers.Parent then return end

    local empty = PageOffers:FindFirstChild("EmptyState")
    if empty then empty.Visible = (#data == 0) end

    local newIds = {}
    for _, offer in pairs(data) do
        if offer.roomId then newIds[tostring(offer.roomId)] = true end
    end

    for id, _ in pairs(renderedOfferIds) do
        if not newIds[id] then
            local existing = PageOffers:FindFirstChild("Offer_" .. id)
            if existing then
                Tween(existing, {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0)}, 0.25)
                task.delay(0.3, function() if existing and existing.Parent then existing:Destroy() end end)
            end
            renderedOfferIds[id] = nil
        end
    end

    for _, offer in pairs(data) do
        local rid = tostring(offer.roomId or "")
        if rid ~= "" and not renderedOfferIds[rid] then
            offerOrderCounter = offerOrderCounter - 1
            local card = CreateOfferCard(PageOffers, offer, false)
            if card then
                card.LayoutOrder = offerOrderCounter
                renderedOfferIds[rid] = true
            end
        end
    end

    task.defer(function()
        if UIListOffers and UIListOffers.Parent then
            local h = UIListOffers.AbsoluteContentSize.Y + 10
            PageOffers.CanvasSize = UDim2.new(0, 0, 0, h)
        end
        
        if currentSearchQuery ~= "" then
            FilterOffers(currentSearchQuery)
        end
    end)
end

--------------------------------------------------------------------------------
-- UPDATE HOST OFFERS (Shows ALL offers from others, regardless of roomId)
--------------------------------------------------------------------------------
local function UpdateHostOffers(offers)
    if not PageHost or not PageHost.Parent then return end
    
    local hostEmpty = PageHost:FindFirstChild("EmptyState")
    
    if offers then
        for _, offer in pairs(offers) do
            local offerFrom = offer.from or offer.username or offer.host or ""
            local offerFromDisplay = offer.displayName or ""
            
            local isFromMe = (offerFrom == LocalPlayer.Name)
                or (offerFrom == LocalPlayer.DisplayName)
                or (offerFromDisplay == LocalPlayer.Name)
                or (offerFromDisplay == LocalPlayer.DisplayName)
                or (offer.userId and offer.userId == LocalPlayer.UserId)
                or (offer.clientId and offer.clientId == my_client_id)
            
            local isUnknown = (offerFrom == "" or offerFrom == "Unknown")
            
            if not isFromMe and not isUnknown then
                local oid = tostring(offer.offerId or offer.roomId or offer.from or "") .. "_" .. tostring(offer.generation or offer.valueNumber or 0)
                
                local found = false
                for _, existingOffer in pairs(allHostOffers) do
                    local existingOid = tostring(existingOffer.offerId or existingOffer.roomId or existingOffer.from or "") .. "_" .. tostring(existingOffer.generation or existingOffer.valueNumber or 0)
                    if existingOid == oid then
                        found = true
                        break
                    end
                end
                
                if not found then
                    table.insert(allHostOffers, offer)
                end
            end
        end
    end

    if #allHostOffers == 0 then
        if hostEmpty then 
            hostEmpty.Visible = true 
            if my_current_room_id then
                hostEmpty.Text = "⏳  Waiting for offers on your listing..."
            else
                hostEmpty.Text = "📭  No incoming offers\nCreate an offer to start receiving"
            end
        end
        return
    end

    if hostEmpty then hostEmpty.Visible = false end

    for _, offer in pairs(allHostOffers) do
        local oid = tostring(offer.offerId or offer.roomId or offer.from or "") .. "_" .. tostring(offer.generation or offer.valueNumber or 0)
        if oid ~= "" and not renderedHostOfferIds[oid] then
            hostOrderCounter = hostOrderCounter - 1
            local card = CreateOfferCard(PageHost, offer, true)
            if card then
                card.LayoutOrder = hostOrderCounter
                renderedHostOfferIds[oid] = true
            end
        end
    end

    task.defer(function()
        if UIListHost and UIListHost.Parent then
            local h = UIListHost.AbsoluteContentSize.Y + 10
            PageHost.CanvasSize = UDim2.new(0, 0, 0, h)
        end
    end)
end

--------------------------------------------------------------------------------
-- WEBSOCKET CONNECTION
--------------------------------------------------------------------------------
spawn(function()
    if not WebSocket then return end

    local ok, result = pcall(function()
        return WebSocket("ws://chillihub.pro:8080")
    end)

    if not ok then
        StatusLabel.Text = "FAIL"
        return
    end

    ws = result

    ws.OnMessage:Connect(function(msg)
        local s, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not s or not data then return end

        if data.type == "connect_success" then
            WsSend({type = "identify", name = LocalPlayer.Name, displayName = LocalPlayer.DisplayName})

        elseif data.type == "identify_ok" then
            isConnected = true
            StatusLabel.Text = "ONLINE"
            Tween(StatusDot, {BackgroundColor3 = Colors.Success}, 0.3)
            Tween(StatusLabel, {TextColor3 = Colors.Success}, 0.3)
            StartPingLoop()

        elseif data.type == "pong" then
            local latency = math.floor((tick() - pingTimestamp) * 1000)
            PingLabel.Text = latency .. "ms"
            PingLabel.TextColor3 = latency < 80 and Colors.Success or latency < 200 and Colors.Accent or Colors.Danger

        elseif data.type == "wager_list_update" then
            if data.data then 
                UpdateOffersList(data.data)
            end

        elseif data.type == "host_offers_update" then
            if data.offers then
                UpdateHostOffers(data.offers)
            end
        end
    end)

    ws.OnClose:Connect(function()
        isConnected = false
        StatusLabel.Text = "CLOSED"
        Tween(StatusDot, {BackgroundColor3 = Colors.Danger}, 0.3)
        Tween(StatusLabel, {TextColor3 = Colors.TextMuted}, 0.3)
        PingLabel.Text = ""
    end)
end)

