--------------------------------------------------------------------------------
-- TAB SWITCHING
--------------------------------------------------------------------------------
local currentTab = "OFFERS"
local pages = {OFFERS = PageOffers, POST = PagePost, HOST = PageHost}

local function SwitchTab(tab)
    if currentTab == tab then return end

    pages[currentTab].Visible = false
    pages[tab].Visible = true

    local btnTarget = tabButtons[tab]
    if btnTarget then
        Tween(TabIndicator, {Position = UDim2.new(0, btnTarget.Position.X.Offset, 1, -3), Size = UDim2.new(0, tabWidth, 0, 3)}, 0.3)
        Tween(IndicatorGlow, {Position = UDim2.new(0, btnTarget.Position.X.Offset, 1, -6), Size = UDim2.new(0, tabWidth, 0, 8)}, 0.3)
    end

    for name, btn in pairs(tabButtons) do
        Tween(btn, {TextColor3 = (name == tab) and Colors.TextPrimary or Colors.TextMuted}, 0.25)
    end

    SearchContainer.Visible = (tab == "OFFERS")
    currentTab = tab
end

for name, btn in pairs(tabButtons) do
    btn.MouseButton1Click:Connect(function()
        RippleEffect(btn)
        SwitchTab(name)
    end)
end

tabButtons["OFFERS"].TextColor3 = Colors.TextPrimary

--------------------------------------------------------------------------------
-- WEBSOCKET FUNCTIONS
--------------------------------------------------------------------------------
local function WsSend(payload)
    if not ws then return false end
    local ok = pcall(function() ws:Send(HttpService:JSONEncode(payload)) end)
    return ok
end

local function StartPingLoop()
    spawn(function()
        while isConnected and ws do
            pingTimestamp = tick()
            local ok = WsSend({type = "ping", timestamp = pingTimestamp, clientId = my_client_id})
            if not ok then
                isConnected = false
                StatusLabel.Text = "LOST"
                Tween(StatusDot, {BackgroundColor3 = Color3.fromRGB(255, 150, 0)}, 0.3)
                PingLabel.Text = ""
                break
            end
            task.wait(15)
        end
    end)
end

